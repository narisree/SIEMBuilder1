def test_full_mimikatz_rule():
    """Integration test: full mimikatz detection rule against test logs."""
    evaluator = SigmaDetectionEvaluator()
    
    # Actual test logs from the project
    test_logs = [
        {
            "EventID": 4688,
            "Image": "C:\\Tools\\mimikatz.exe",
            "CommandLine": "mimikatz.exe sekurlsa::logonpasswords",
            "User": "CORP\\Administrator",
            "ParentImage": "C:\\Windows\\System32\\cmd.exe",
        },
        {
            "EventID": 4688,
            "Image": "C:\\Program Files\\mimikatz\\mimikatz.exe",
            "CommandLine": "mimikatz lsadump::sam",
            "User": "WORKGROUP\\admin",
            "ParentImage": "C:\\Windows\\System32\\powershell.exe",
        },
        {
            "EventID": 4688,
            "Image": "C:\\Windows\\notepad.exe",
            "CommandLine": "notepad.exe",
            "User": "CORP\\User",
            "ParentImage": "C:\\Windows\\explorer.exe",
        }
    ]
    
    # Actual Sigma rule detection block
    rule_yaml = """
title: Mimikatz Detection via Process Creation
detection:
    selection:
        Image|endswith: '\\mimikatz.exe'
    selection_cmdline:
        CommandLine|contains:
            - 'sekurlsa'
