def test_parenthesized_condition():
    """Test parenthesized conditions: (sel1 or sel2) and not filter."""
    evaluator = SigmaDetectionEvaluator()
    
    df = pd.DataFrame([
        {"Image": "mimikatz.exe", "CommandLine": "sekurlsa", "User": "admin"},
        {"Image": "cmd.exe", "CommandLine": "sekurlsa", "User": "SYSTEM"},
        {"Image": "cmd.exe", "CommandLine": "normal", "User": "user1"},
        {"Image": "mimikatz.exe", "CommandLine": "normal", "User": "SYSTEM"},
    ])
    
    detection = {
        "sel1": {"Image": "*mimikatz*"},
        "sel2": {"CommandLine|contains": "sekurlsa"},
        "filter": {"User": "SYSTEM"},
        "condition": "(sel1 or sel2) and not filter"
    }
    
    result = evaluator.evaluate(df, detection)
    # Row 0: mimikatz + sekurlsa, not SYSTEM => match
    # Row 1: sekurlsa, but SYSTEM => filtered
    # Row 2: neither sel1 nor sel2 => no match
    # Row 3: mimikatz, but SYSTEM => filtered
    assert len(result) == 1, f"Expected 1 match, got {len(result)}"
    assert result.iloc[0]["User"] == "admin"
    print("✅ test_parenthesized_condition PASSED")


