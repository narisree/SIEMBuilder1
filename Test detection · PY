def test_basic_selection():
    """Test basic single-selection matching."""
    evaluator = SigmaDetectionEvaluator()
    
    df = pd.DataFrame([
        {"Image": "C:\\Tools\\mimikatz.exe", "User": "admin"},
        {"Image": "C:\\Windows\\notepad.exe", "User": "user1"},
    ])
    
    detection = {
        "selection": {"Image": "*mimikatz.exe"},
        "condition": "selection"
    }
    
    result = evaluator.evaluate(df, detection)
    assert len(result) == 1, f"Expected 1 match, got {len(result)}"
    assert "mimikatz" in result.iloc[0]["Image"]
    print("✅ test_basic_selection PASSED")


def test_or_condition():
    """Test OR condition between two selections — the main bug fix."""
    evaluator = SigmaDetectionEvaluator()
    
    # Mimikatz detection rule: selection OR selection_cmdline
    df = pd.DataFrame([
        {"Image": "C:\\Tools\\mimikatz.exe", "CommandLine": "mimikatz.exe sekurlsa::logonpasswords"},
        {"Image": "C:\\Program Files\\mimikatz\\mimikatz.exe", "CommandLine": "mimikatz lsadump::sam"},
        {"Image": "C:\\Windows\\notepad.exe", "CommandLine": "notepad.exe"},
        {"Image": "C:\\Windows\\cmd.exe", "CommandLine": "cmd.exe /c sekurlsa::logonpasswords"},
    ])
    
    detection = {
        "selection": {
            "Image|endswith": "\\mimikatz.exe"
        },
        "selection_cmdline": {
            "CommandLine|contains": ["sekurlsa", "logonpasswords", "lsadump"]
        },
        "condition": "selection or selection_cmdline"
    }
    
    result = evaluator.evaluate(df, detection)
    # Should match: row 0 (both), row 1 (both), row 3 (cmdline only) = 3 matches
    assert len(result) == 3, f"Expected 3 matches, got {len(result)}: {result['Image'].tolist()}"
    print("✅ test_or_condition PASSED")


